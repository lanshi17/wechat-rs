# ── PostgreSQL ────────────────────────────────────────────────────────────────
# 注意: POSTGRES_PASSWORD 会被拼进 DATABASE_URL，特殊字符需 URL 编码
POSTGRES_DB=wechat
POSTGRES_USER=wechat
POSTGRES_PASSWORD=your_password_here

# ── 管理后台 ─────────────────────────────────────────────────────────────────
# 首次登录密码（登录成功后自动 bcrypt 写入数据库，之后此变量可清空）
ADMIN_PASSWORD=admin123

# JWT 签名密钥（随机字符串，越长越好）
ADMIN_SECRET=please_change_this_to_a_long_random_string

# ── 微信（可在管理后台动态配置，此处作为初始值）────────────────────────────
WECHAT_TOKEN=
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_ENCODING_AES_KEY=

# ── 上游网站 API 访问令牌 ──────────────────────────────────────────────────
WECHAT_SERVER_TOKEN=

# ── 存储后端 ────────────────────────────────────────────────────────────────
# 可选: postgres / redis
STORAGE_TYPE=postgres

# PostgreSQL 连接（STORAGE_TYPE=postgres 时必填）
# DATABASE_URL=postgres://wechat:password@localhost:5432/wechat

# Redis 连接（STORAGE_TYPE=redis 时必填）
# REDIS_URL=redis://localhost:6379

# ── 服务 ─────────────────────────────────────────────────────────────────────
LISTEN_PORT=3000
DOMAIN=localhost
SITE_NAME=微信服务管理后台
